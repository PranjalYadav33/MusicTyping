{
  "name": "musictype",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "main": "main.cjs",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "electron:dev": "cross-env NODE_ENV=development concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build:electron": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.musictype.app",
    "productName": "MusicType",
    "artifactName": "MusicType-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "public/logo.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/logo.png"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "out/**/*",
      "public/**/*",
      ".bin/**/*"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.7.0",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "play-dl": "^1.9.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ytmusic-api": "^5.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4"
  }
}
